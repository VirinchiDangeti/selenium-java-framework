<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Selenium BDD Framework Suite"
       parallel="methods"
       thread-count="2"
       verbose="1">

    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="staging"/>

    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
    </listeners>

    <test name="BDD Cucumber Tests">
        <classes>
            <class name="com.framework.runners.CucumberRunner"/>
        </classes>
    </test>

</suite>